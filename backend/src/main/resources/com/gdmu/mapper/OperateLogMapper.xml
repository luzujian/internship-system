<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.OperateLogMapper">

    <delete id="cleanOldLogsByRole">
        delete from operate_log 
        where operator_role = #{operatorRole} 
        and id not in 
        <foreach item="item" collection="keepIds" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

</mapper>
