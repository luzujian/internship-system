<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.CounselorKeywordMapper">
    
    <resultMap id="CounselorKeywordResultMap" type="com.gdmu.entity.CounselorKeyword">
        <id property="id" column="id" />
        <result property="counselorId" column="counselor_id" />
        <result property="keyword" column="keyword" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <insert id="insert" parameterType="com.gdmu.entity.CounselorKeyword" useGeneratedKeys="true" keyProperty="id">
        insert into counselor_keyword (counselor_id, keyword, status, create_time, update_time)
        values (#{counselorId}, #{keyword}, #{status}, #{createTime}, #{updateTime})
    </insert>
    
    <select id="findById" resultMap="CounselorKeywordResultMap">
        select * from counselor_keyword where id = #{id}
    </select>
    
    <select id="findByCounselorId" resultMap="CounselorKeywordResultMap">
        select * from counselor_keyword 
        where counselor_id = #{counselorId}
        order by status desc, id desc
    </select>
    
    <update id="update" parameterType="com.gdmu.entity.CounselorKeyword">
        update counselor_keyword
        <set>
            <if test="keyword != null">
                keyword = #{keyword},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            update_time = #{updateTime}
        </set>
        where id = #{id}
    </update>
    
    <delete id="deleteById">
        delete from counselor_keyword where id = #{id}
    </delete>
    
    <delete id="deleteByCounselorId">
        delete from counselor_keyword where counselor_id = #{counselorId}
    </delete>

    <select id="countByCounselorId" resultType="int">
        select count(*) from counselor_keyword where counselor_id = #{counselorId}
    </select>
</mapper>
