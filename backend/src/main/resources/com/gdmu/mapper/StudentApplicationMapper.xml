<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.StudentApplicationMapper">
    
    <!-- 定义学生申请结果映射 -->
    <resultMap id="StudentApplicationResultMap" type="com.gdmu.entity.StudentApplication">
        <id property="id" column="id" />
        <result property="studentId" column="student_id" />
        <result property="studentName" column="student_name" />
        <result property="studentUserId" column="student_user_id" />
        <result property="grade" column="grade" />
        <result property="className" column="class_name" />
        <result property="applicationType" column="application_type" />
        <result property="reason" column="reason" />
        <result property="company" column="company" />
        <result property="oldCompany" column="old_company" />
        <result property="newCompany" column="new_company" />
        <result property="materials" column="materials" typeHandler="com.gdmu.handler.JsonMapTypeHandler" />
        <result property="status" column="status" />
        <result property="rejectReason" column="reject_reason" />
        <result property="reviewerId" column="reviewer_id" />
        <result property="reviewTime" column="review_time" />
        <result property="applyTime" column="apply_time" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <!-- 插入学生申请 -->
    <insert id="insert" parameterType="com.gdmu.entity.StudentApplication" useGeneratedKeys="true" keyProperty="id">
        insert into student_application (student_id, student_name, student_user_id, grade, class_name, application_type, reason, company, old_company, new_company, materials, status, reject_reason, reviewer_id, review_time, apply_time, create_time, update_time)
        values (#{studentId}, #{studentName}, #{studentUserId}, #{grade}, #{className}, #{applicationType}, #{reason}, #{company}, #{oldCompany}, #{newCompany}, #{materials, typeHandler=com.gdmu.handler.JsonMapTypeHandler}, #{status}, #{rejectReason}, #{reviewerId}, #{reviewTime}, #{applyTime}, NOW(), NOW())
    </insert>
    
    <!-- 根据ID查询学生申请 -->
    <select id="findById" resultMap="StudentApplicationResultMap">
        select * from student_application where id = #{id}
    </select>
    
    <!-- 根据学生ID查询申请列表 -->
    <select id="findByStudentId" resultMap="StudentApplicationResultMap">
        select * from student_application where student_id = #{studentId} order by apply_time desc
    </select>
    
    <!-- 更新学生申请 -->
    <update id="update" parameterType="com.gdmu.entity.StudentApplication">
        update student_application
        <set>
            <if test="studentId != null">
                student_id = #{studentId},
            </if>
            <if test="studentName != null and studentName != ''">
                student_name = #{studentName},
            </if>
            <if test="studentUserId != null and studentUserId != ''">
                student_user_id = #{studentUserId},
            </if>
            <if test="grade != null">
                grade = #{grade},
            </if>
            <if test="className != null">
                class_name = #{className},
            </if>
            <if test="applicationType != null and applicationType != ''">
                application_type = #{applicationType},
            </if>
            <if test="reason != null and reason != ''">
                reason = #{reason},
            </if>
            <if test="company != null">
                company = #{company},
            </if>
            <if test="oldCompany != null">
                old_company = #{oldCompany},
            </if>
            <if test="newCompany != null">
                new_company = #{newCompany},
            </if>
            <if test="materials != null">
                materials = #{materials, typeHandler=com.gdmu.handler.JsonMapTypeHandler},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="rejectReason != null">
                reject_reason = #{rejectReason},
            </if>
            <if test="reviewerId != null">
                reviewer_id = #{reviewerId},
            </if>
            <if test="reviewTime != null">
                review_time = #{reviewTime},
            </if>
            update_time = NOW()
        </set>
        where id = #{id}
    </update>
    
    <!-- 删除学生申请 -->
    <delete id="deleteById">
        delete from student_application where id = #{id}
    </delete>
    
    <!-- 查询所有学生申请 -->
    <select id="findAll" resultMap="StudentApplicationResultMap">
        select * from student_application order by apply_time desc
    </select>
    
    <!-- 动态条件查询学生申请 -->
    <select id="list" resultMap="StudentApplicationResultMap">
        select * from student_application
        <where>
            <if test="applicationType != null and applicationType != ''">
                and application_type = #{applicationType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="studentName != null and studentName != ''">
                and student_name like concat('%',#{studentName},'%')
            </if>
            <if test="studentUserId != null and studentUserId != ''">
                and student_user_id like concat('%',#{studentUserId},'%')
            </if>
        </where>
        order by apply_time desc
    </select>
    
    <!-- 根据ID列表查询学生申请 -->
    <select id="selectByIds" resultType="com.gdmu.entity.StudentApplication" parameterType="java.util.List">
        SELECT * FROM student_application WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    
    <!-- 批量删除学生申请 -->
    <delete id="batchDeleteByIds" parameterType="java.util.List">
        DELETE FROM student_application WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <!-- 查询学生申请总数 -->
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM student_application
    </select>
    
    <!-- 分页查询学生申请 -->
    <select id="findPage" resultMap="StudentApplicationResultMap">
        SELECT * FROM student_application 
        ORDER BY apply_time DESC 
        LIMIT #{offset}, #{pageSize}
    </select>
    
    <!-- 根据申请类型和状态查询申请数量 -->
    <select id="countByTypeAndStatus" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM student_application 
        WHERE application_type = #{applicationType} 
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
    </select>
    
    <!-- 根据状态查询申请数量 -->
    <select id="countByStatus" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM student_application 
        WHERE status = #{status}
    </select>

    <!-- 获取待审核申请数量（用于首页统计） -->
    <select id="countPendingApproval" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM student_application
        WHERE status = 'pending'
    </select>

    <!-- 根据时间范围统计申请数量 -->
    <select id="countByTimeRange" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM student_application
        WHERE apply_time BETWEEN #{startDate} AND #{endDate}
    </select>
</mapper>
