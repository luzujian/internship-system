<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.TemplateFileMapper">
    
    <resultMap id="TemplateFileResultMap" type="com.gdmu.entity.TemplateFile">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="category" column="category" />
        <result property="fileUrl" column="file_url" />
        <result property="description" column="description" />
        <result property="downloadCount" column="download_count" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <insert id="insert" parameterType="com.gdmu.entity.TemplateFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO template_file (name, category, file_url, description, download_count, status, create_time, update_time)
        VALUES (#{name}, #{category}, #{fileUrl}, #{description}, #{downloadCount}, #{status}, #{createTime}, #{updateTime})
    </insert>
    
    <select id="findById" resultMap="TemplateFileResultMap">
        SELECT * FROM template_file WHERE id = #{id}
    </select>
    
    <update id="update" parameterType="com.gdmu.entity.TemplateFile">
        UPDATE template_file
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="category != null">category = #{category},</if>
            <if test="fileUrl != null and fileUrl != ''">file_url = #{fileUrl},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM template_file WHERE id = #{id}
    </delete>
    
    <select id="findAll" resultMap="TemplateFileResultMap">
        SELECT * FROM template_file ORDER BY create_time DESC
    </select>
    
    <select id="list" resultMap="TemplateFileResultMap">
        SELECT * FROM template_file
        <where>
            <if test="name != null and name != ''">
                name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
    
    <update id="incrementDownloadCount">
        UPDATE template_file SET download_count = download_count + 1 WHERE id = #{id}
    </update>
    
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM template_file
    </select>
    
    <delete id="batchDeleteByIds" parameterType="java.util.List">
        DELETE FROM template_file WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
