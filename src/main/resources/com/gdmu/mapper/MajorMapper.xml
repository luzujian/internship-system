<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gdmu.mapper.MajorMapper">
    <!-- 定义结果映射，确保实体类属性与数据库字段正确映射 -->
    <resultMap id="MajorResultMap" type="com.gdmu.entity.Major">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="departmentId" column="department_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="teacherCount" column="teacher_count"/>
        <result property="studentCount" column="student_count"/>
        <result property="confirmedCount" column="confirmed_count"/>
        <result property="notFoundCount" column="not_found_count"/>
        <result property="hasOfferCount" column="has_offer_count"/>
    </resultMap>
    
    <!-- 根据ID查询专业 -->
    <select id="findById" parameterType="java.lang.Long" resultMap="MajorResultMap">
        SELECT * FROM major WHERE id = #{id}
    </select>
    
    <!-- 查询所有专业 -->
    <select id="findAll" resultMap="MajorResultMap">
        SELECT * FROM major
        order by update_time desc
    </select>
    
    <!-- 新增专业 -->
    <insert id="insert" parameterType="com.gdmu.entity.Major" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO major(name, department_id, create_time, update_time)
        VALUES(#{name}, #{departmentId}, #{createTime}, #{updateTime})
    </insert>
    
    <!-- 更新专业 -->
    <update id="update" parameterType="com.gdmu.entity.Major">
        UPDATE major
        SET name=#{name}, department_id=#{departmentId}, update_time=#{updateTime}
        WHERE id=#{id}
    </update>
    
    <!-- 删除专业 -->
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM major WHERE id = #{id}
    </delete>
    
    <!-- 根据名称搜索专业 -->
    <select id="findByName" parameterType="java.lang.String" resultMap="MajorResultMap">
        SELECT * FROM major WHERE name LIKE CONCAT('%', #{name}, '%')
    </select>
    
    <!-- 根据院系ID查询专业 -->
    <select id="findByDepartmentId" parameterType="java.lang.Long" resultMap="MajorResultMap">
        SELECT * FROM major WHERE department_id = #{departmentId}
    </select>
    
    <!-- 根据专业ID查询教师人数 -->
    <select id="getTeacherCountByMajorId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        <!-- 由于course表不存在，直接返回0 -->
        select 0
    </select>
    
    <!-- 根据专业ID查询学生人数 -->
    <select id="getStudentCountByMajorId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        select count(1) from student_users where major_id = #{majorId}
    </select>
    
    <!-- 更新专业人数信息 -->
    <update id="updateMajorCount" parameterType="map">
        update major
        set
        <if test="teacherCount != null">
            teacher_count = #{teacherCount},
        </if>
        student_count = #{studentCount},
        update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>
    
    <!-- 根据专业ID查询已确定实习的学生数 -->
    <select id="getConfirmedCountByMajorId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        SELECT COUNT(*) FROM student_internship_status sis
        INNER JOIN student_users su ON sis.student_id = su.id
        WHERE su.major_id = #{majorId} AND sis.status = 2
    </select>
    
    <!-- 根据专业ID查询未找到实习的学生数 -->
    <select id="getNotFoundCountByMajorId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        SELECT COUNT(*) FROM student_users su
        LEFT JOIN student_internship_status sis ON su.id = sis.student_id
        WHERE su.major_id = #{majorId} AND (sis.status = 0 OR sis.status IS NULL)
    </select>
    
    <!-- 根据专业ID查询有Offer未确定的学生数 -->
    <select id="getHasOfferCountByMajorId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        SELECT COUNT(*) FROM student_internship_status sis
        INNER JOIN student_users su ON sis.student_id = su.id
        WHERE su.major_id = #{majorId} AND sis.status = 1
    </select>
    
    <!-- 更新专业实习状态统计信息 -->
    <update id="updateMajorInternshipCount" parameterType="map">
        update major
        set confirmed_count = #{confirmedCount},
            not_found_count = #{notFoundCount},
            has_offer_count = #{hasOfferCount},
            update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>
    
    <!-- 查询专业总数 -->
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM major
    </select>
</mapper>