<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.ResourceCategoryMapper">
    
    <select id="selectByParentId" resultType="com.gdmu.entity.ResourceCategory">
        SELECT * FROM resource_categories WHERE parent_id = #{parentId} ORDER BY id
    </select>
    
    <select id="selectTopCategories" resultType="com.gdmu.entity.ResourceCategory">
        SELECT * FROM resource_categories WHERE parent_id IS NULL ORDER BY id
    </select>
</mapper>