<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.StudentUserMapper">
    
    <!-- 定义学生用户结果映射 -->
    <resultMap id="StudentUserResultMap" type="com.gdmu.entity.StudentUser">
        <id property="id" column="id" />
        <result property="password" column="password" />
        <result property="role" column="role" />
        <result property="name" column="name" />
        <result property="gender" column="gender" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="lastLoginTime" column="last_login_time" />
        <result property="status" column="status" />
        <result property="studentId" column="student_user_id" />
        <result property="majorId" column="major_id" />
        <result property="grade" column="grade" />
        <result property="classId" column="class_id" />
        <result property="className" column="className" />
    </resultMap>
    
    <!-- 根据学号查询学生用户 -->
    <select id="findByStudentId" parameterType="String" resultMap="StudentUserResultMap">
        select * from student_users where student_user_id = #{studentId}
    </select>
    
    <!-- 插入学生用户 -->
    <insert id="insert" parameterType="com.gdmu.entity.StudentUser">
        insert into student_users (username, student_user_id, name, create_time, update_time, major_id, grade, class_id, password)
        values (#{username}, #{studentId}, #{name}, #{createTime}, #{updateTime}, #{majorId}, #{grade}, #{classId}, #{password})
    </insert>
    
    <!-- 根据ID查询学生用户 -->
    <select id="findById" resultMap="StudentUserResultMap">
        select * from student_users where id = #{id}
    </select>
    
    <!-- 更新学生用户信息 -->
    <update id="update" parameterType="com.gdmu.entity.StudentUser">
        update student_users
        <set>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="gender != null">
                gender = #{gender},
            </if>
            <if test="studentId != null and studentId != ''">
                student_user_id = #{studentId},
            </if>
            <if test="grade != null">
                grade = #{grade},
            </if>
            <if test="classId != null">
                class_id = #{classId},
            </if>
            <if test="majorId != null">
                major_id = #{majorId},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime}
            </if>
        </set>
        where id = #{id}
    </update>
    
    <!-- 查询所有学生用户 -->
    <select id="findAll" resultMap="StudentUserResultMap">
        select * from student_users
    </select>

    <!-- 动态条件查询 -->
    <select id="list" resultMap="StudentUserResultMap">
        select s.*, c.name className from student_users s left join class c on s.class_id = c.id
        <where>
            <if test="studentId != null and studentId != '' or name != null and name != ''">
                <trim prefix="(" suffix=")" prefixOverrides="or">
                    <if test="studentId != null and studentId != ''">
                        s.student_user_id like concat('%',#{studentId},'%')
                    </if>
                    <if test="name != null and name != ''">
                        <if test="studentId != null and studentId != ''">
                            or
                        </if>
                        s.name like concat('%',#{name},'%')
                    </if>
                </trim>
                <if test="grade != null or majorId != null or classId != null">
                    and
                </if>
            </if>
            <if test="grade != null">
                and s.grade = #{grade}
            </if>
            <if test="majorId != null">
                and s.major_id = #{majorId}
            </if>
            <if test="classId != null">
                and s.class_id = #{classId}
            </if>
        </where>
        order by s.update_time desc
    </select>
    
    <!-- 动态条件查询（包含状态参数） -->
    <select id="listWithStatus" resultMap="StudentUserResultMap">
        select s.*, c.name className from student_users s left join class c on s.class_id = c.id
        <where>
            <if test="studentId != null and studentId != '' or name != null and name != ''">
                <trim prefix="(" suffix=")" prefixOverrides="or">
                    <if test="studentId != null and studentId != ''">
                        s.student_user_id like concat('%',#{studentId},'%')
                    </if>
                    <if test="name != null and name != ''">
                        <if test="studentId != null and studentId != ''">
                            or
                        </if>
                        s.name like concat('%',#{name},'%')
                    </if>
                </trim>
                <if test="grade != null or majorId != null or classId != null or status != null or gender != null">
                    and
                </if>
            </if>
            <if test="grade != null">
                and s.grade = #{grade}
            </if>
            <if test="majorId != null">
                and s.major_id = #{majorId}
            </if>
            <if test="classId != null">
                and s.class_id = #{classId}
            </if>
            <if test="status != null">
                and s.status = #{status}
            </if>
            <if test="gender != null">
                and s.gender = #{gender}
            </if>
        </where>
        order by s.update_time desc
    </select>
    
    <!-- 根据ID列表查询学生用户 -->
    <select id="selectByIds" resultType="com.gdmu.entity.StudentUser" parameterType="java.util.List">
        SELECT * FROM student_users WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    
    <!-- 根据学号列表批量查询学生用户 -->
    <select id="findByStudentIds" resultType="com.gdmu.entity.StudentUser" parameterType="java.util.List">
        SELECT * FROM student_users WHERE student_user_id IN
        <foreach collection="studentIds" item="studentUserId" open="(" separator="," close=")">
            #{studentUserId}
        </foreach>
    </select>
    
    <!-- 批量插入学生用户 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO student_users (username, student_user_id, name, gender, password, create_time, update_time, major_id, grade, class_id)
        VALUES
        <foreach collection="studentUsers" item="studentUser" separator=",">
            (#{studentUser.username}, #{studentUser.studentId}, #{studentUser.name}, #{studentUser.gender}, #{studentUser.password}, #{studentUser.createTime}, #{studentUser.updateTime}, #{studentUser.majorId}, #{studentUser.grade}, #{studentUser.classId})
        </foreach>
    </insert>
    
    <!-- 更新依赖记录 -->
    <update id="updateGroupLeaderToNull" parameterType="java.util.List">
        UPDATE group_table 
        SET 
            leader_student_id = NULL
        WHERE leader_student_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
    
    <!-- 直接更新特定小组的所有组长相关字段为null -->
    <update id="updateSpecificGroupLeadersToNull" parameterType="java.lang.Long">
        UPDATE group_table 
        SET 
            leader_student_id = NULL,
            leader_teacher_id = NULL
        WHERE id = #{groupId}
    </update>
    
    <!-- 批量删除学生用户 -->
    <delete id="batchDeleteByIds" parameterType="java.util.List">
        DELETE FROM student_users WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <!-- 根据班级ID查询学生数量 -->
    <select id="countByClassId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        SELECT COUNT(*) FROM student_users WHERE class_id = #{classId}
    </select>
    
    <!-- 根据班级ID查询所有学生 -->
    <select id="findByClassId" resultType="com.gdmu.entity.StudentUser" parameterType="java.lang.Long">
        SELECT * FROM student_users WHERE class_id = #{classId}
    </select>
    
    <!-- 根据课程ID列表查询学生信息 -->
    <select id="findStudentsByCourseIds" resultType="java.util.Map">
        SELECT DISTINCT
            su.id AS id,
            su.student_id AS studentId,
            su.name AS studentName,
            su.grade AS grade,
            c.name AS className,
            m.name AS majorName
        FROM 
            student_users su
        LEFT JOIN 
            class c ON su.class_id = c.id
        LEFT JOIN 
            major m ON su.major_id = m.id
        INNER JOIN 
            student_course sc ON su.id = sc.student_user_id
        <where>
            <if test="courseIds != null and courseIds.size() > 0">
                sc.course_id IN 
                <foreach collection="courseIds" item="courseId" open="(" separator="," close=")">
                    #{courseId}
                </foreach>
            </if>
            <if test="searchName != null and searchName != ''">
                AND su.name LIKE CONCAT('%', #{searchName}, '%')
            </if>
            <if test="classId != null">
                AND su.class_id = #{classId}
            </if>
        </where>
        ORDER BY su.student_id ASC
    </select>
    
    <!-- 根据专业ID查询学生数量 -->
    <select id="countByMajorId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM student_users WHERE major_id = #{majorId}
    </select>
    
    <!-- 查询所有学生 -->
    <select id="selectAll" resultType="com.gdmu.entity.StudentUser">
        SELECT * FROM student_users ORDER BY create_time DESC
    </select>
</mapper>