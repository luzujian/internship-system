<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdmu.mapper.ResourceDocumentMapper">
    
    <resultMap id="ResourceDocumentResultMap" type="com.gdmu.entity.ResourceDocument">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="description" column="description" />
        <result property="fileUrl" column="file_url" />
        <result property="fileName" column="file_name" />
        <result property="fileType" column="file_type" />
        <result property="fileSize" column="file_size" />
        <result property="publisherId" column="publisher_id" />
        <result property="publisher" column="publisher" />
        <result property="publisherRole" column="publisher_role" />
        <result property="publishTime" column="publish_time" />
        <result property="targetType" column="target_type" />
        <result property="targetValue" column="target_value" />
        <result property="status" column="status" />
        <result property="downloadCount" column="download_count" />
        <result property="viewCount" column="view_count" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <insert id="insert" parameterType="com.gdmu.entity.ResourceDocument" useGeneratedKeys="true" keyProperty="id">
        insert into resource_documents (title, description, file_url, file_name, file_type, file_size, publisher_id, publisher, publisher_role, publish_time, target_type, target_value, status, download_count, view_count)
        values (#{title}, #{description}, #{fileUrl}, #{fileName}, #{fileType}, #{fileSize}, #{publisherId}, #{publisher}, #{publisherRole}, #{publishTime}, #{targetType}, #{targetValue}, #{status}, 0, 0)
    </insert>
    
    <select id="findById" resultMap="ResourceDocumentResultMap">
        select * from resource_documents where id = #{id}
    </select>
    
    <update id="update" parameterType="com.gdmu.entity.ResourceDocument">
        update resource_documents
        <set>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="fileUrl != null and fileUrl != ''">
                file_url = #{fileUrl},
            </if>
            <if test="fileName != null and fileName != ''">
                file_name = #{fileName},
            </if>
            <if test="fileType != null and fileType != ''">
                file_type = #{fileType},
            </if>
            <if test="fileSize != null">
                file_size = #{fileSize},
            </if>
            <if test="publisherId != null">
                publisher_id = #{publisherId},
            </if>
            <if test="publisher != null and publisher != ''">
                publisher = #{publisher},
            </if>
            <if test="publisherRole != null and publisherRole != ''">
                publisher_role = #{publisherRole},
            </if>
            <if test="publishTime != null">
                publish_time = #{publishTime},
            </if>
            <if test="targetType != null and targetType != ''">
                target_type = #{targetType},
            </if>
            <if test="targetValue != null">
                target_value = #{targetValue},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            update_time = NOW()
        </set>
        where id = #{id}
    </update>
    
    <delete id="deleteById">
        delete from resource_documents where id = #{id}
    </delete>
    
    <select id="findAll" resultMap="ResourceDocumentResultMap">
        select * from resource_documents order by create_time desc
    </select>
    
    <select id="list" resultMap="ResourceDocumentResultMap">
        select * from resource_documents
        <where>
            <if test="title != null and title != ''">
                and title like concat('%',#{title},'%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="publisherRole != null and publisherRole != ''">
                and publisher_role = #{publisherRole}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectByIds" resultType="com.gdmu.entity.ResourceDocument" parameterType="java.util.List">
        SELECT * FROM resource_documents WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    
    <delete id="batchDeleteByIds" parameterType="java.util.List">
        DELETE FROM resource_documents WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM resource_documents
    </select>
    
    <select id="findPage" resultMap="ResourceDocumentResultMap">
        SELECT * FROM resource_documents
        <where>
            <if test="title != null and title != ''">
                and title like concat('%',#{title},'%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="publisherRole != null and publisherRole != ''">
                and publisher_role = #{publisherRole}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    
    <update id="incrementDownloadCount">
        update resource_documents set download_count = download_count + 1 where id = #{id}
    </update>
    
    <update id="incrementViewCount">
        update resource_documents set view_count = view_count + 1 where id = #{id}
    </update>
</mapper>
